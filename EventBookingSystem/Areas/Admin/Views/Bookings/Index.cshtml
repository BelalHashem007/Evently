@model IReadOnlyList<AdminBookingListItemViewModel>

@{
    ViewData["Title"] = "Bookings";
}

<div class="mb-4">
    <h1 class="h3 mb-1">Bookings</h1>
    <p class="text-muted mb-0">Read-only booking overview for admins.</p>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Event</th>
                    <th>User</th>
                    <th>Status</th>
                    <th>Total</th>
                    <th>Expires</th>
                    <th>Created</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">No bookings found.</td>
                    </tr>
                }
                else
                {
                    @foreach (var booking in Model)
                    {
                        <tr>
                            <td>#@booking.Id</td>
                            <td>@booking.EventName</td>
                            <td>@booking.UserName</td>
                            <td><span class="badge text-bg-secondary">@booking.Status</span></td>
                            <td>@booking.TotalPrice.ToString("C")</td>
                            <td>@(booking.ExpiresAt?.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt") ?? "-")</td>
                            <td>@booking.CreatedDate.ToString("MMM dd, yyyy")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
