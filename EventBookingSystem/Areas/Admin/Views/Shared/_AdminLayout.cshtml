<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin - EventBookingSystem</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EventBookingSystem.styles.css" asp-append-version="true" />
</head>
<body class="mb-0">
    <div class="d-flex min-vh-100">
        <aside class="border-end bg-light p-3" style="width: 260px;">
            <a class="navbar-brand d-block fw-semibold mb-4" asp-area="Admin" asp-controller="Home" asp-action="Index">Admin</a>
            <nav class="nav nav-pills flex-column gap-1">
                <a class="nav-link text-dark" asp-area="Admin" asp-controller="Home" asp-action="Index">Dashboard</a>
                <a class="nav-link text-dark" asp-area="Admin" asp-controller="Events" asp-action="Index">Events</a>
                <a class="nav-link text-dark" asp-area="Admin" asp-controller="Bookings" asp-action="Index">Bookings</a>
                <a class="nav-link text-dark" asp-area="Admin" asp-controller="Users" asp-action="Index">Users</a>
            </nav>
            <hr />
            <a class="btn btn-outline-secondary w-100" asp-area="" asp-controller="Home" asp-action="Index">Back to Site</a>
        </aside>

        <div class="flex-grow-1">
            <header class="border-bottom bg-white">
                <div class="container-fluid py-3 d-flex justify-content-between align-items-center">
                    <span class="fw-semibold">@ViewData["Title"]</span>
                    <div class="d-flex align-items-center gap-3">
                        <span class="text-muted">@User.Identity?.Name</span>
                        <form asp-area="" asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                            <button type="submit" class="btn btn-link text-dark p-0">Logout</button>
                        </form>
                    </div>
                </div>
            </header>

            <main role="main" class="container-fluid p-4">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
