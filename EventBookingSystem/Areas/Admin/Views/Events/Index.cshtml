@model IReadOnlyList<AdminEventListItemViewModel>

@{
    ViewData["Title"] = "Events";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Events</h1>
        <p class="text-muted mb-0">Review all events and open existing event management actions.</p>
    </div>
    <a class="btn btn-primary" asp-area="Admin" asp-controller="Events" asp-action="Create">Create Event</a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Date</th>
                    <th>Venue</th>
                    <th>Ticket Types</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">No events found.</td>
                    </tr>
                }
                else
                {
                    @foreach (var eventItem in Model)
                    {
                        <tr>
                            <td>@eventItem.Name</td>
                            <td>@eventItem.Date.ToString("MMM dd, yyyy")</td>
                            <td>@eventItem.Venue</td>
                            <td>@eventItem.TicketTypeCount</td>
                            <td>
                                @if (eventItem.IsCancelled)
                                {
                                    <span class="badge bg-warning">Cancelled</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                            </td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-secondary" asp-area="" asp-controller="Events" asp-action="Details" asp-route-id="@eventItem.Id">View</a>
                                @if (!eventItem.IsCancelled)
                                {
                                    <a class="btn btn-sm btn-outline-primary" asp-area="Admin" asp-controller="Events" asp-action="Edit" asp-route-id="@eventItem.Id">Edit</a>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
