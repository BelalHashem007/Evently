@model EventBookingSystem.ViewModels.EventCardViewModel
@{
    var dateIso = DateTime.SpecifyKind(Model.Date, DateTimeKind.Utc).ToString("o");
}

<div class="card event-card h-100 shadow-sm">
    <div class="event-card-image-wrap">
        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" class="card-img-top event-card-image" alt="@Model.Name" />
        }
        else
        {
            <div class="event-card-placeholder">
                <span>@Model.Name</span>
            </div>
        }

        <div class="event-date-badge">
            <span class="event-date-badge-month" data-date-badge-month="@dateIso"></span>
            <span class="event-date-badge-day" data-date-badge-day="@dateIso"></span>
        </div>
    </div>

    <div class="card-body d-flex flex-column">
        <h5 class="card-title event-card-title">@Model.Name</h5>
        <div class="event-card-meta">
            <span data-date-card="@dateIso"></span>
            <span class="text-truncate" title="@Model.Venue">@Model.Venue</span>
        </div>
        <p class="event-card-price">
            @Model.PriceRange
        </p>

        <div class="mt-auto d-flex gap-2 flex-wrap">
            <a asp-controller="Events" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-primary flex-grow-1">View Details</a>

            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Events" asp-action="Edit" asp-route-id="@Model.Id" asp-area="Admin" class="btn btn-secondary">Edit</a>
                <button type="button" class="btn btn-danger" data-bs-toggle="modal" asp-area="Admin" data-bs-target="#cancel-event-modal-@Model.Id">Cancel</button>
            }
        </div>
    </div>
</div>

@if (User.IsInRole("Admin"))
{
    var cancelModal = new EventBookingSystem.Areas.Admin.ViewModels.EventCancelModalViewModel
    {
        Id = Model.Id,
        Name = Model.Name,
        ModalId = $"cancel-event-modal-{Model.Id}"
    };

    <partial name="~/Areas/Admin/Views/Events/PartialViews/_CancelEventModal.cshtml"
             model="cancelModal" />
}
