@model EventBookingSystem.ViewModels.EventCardViewModel

<div class="card h-100 shadow-sm">
    @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
    {
        <img src="@Model.ImageUrl" class="card-img-top" alt="@Model.Name" style="height: 220px; object-fit: cover;" />
    }
    else
    {
        <div class="bg-light d-flex align-items-center justify-content-center text-muted" style="height: 220px;">
            No image available
        </div>
    }

    <div class="card-body d-flex flex-column">
        <h5 class="card-title">@Model.Name</h5>
        <p class="card-text mb-1">
            <strong>Date:</strong> @Model.Date.ToString("MMM dd, yyyy")
        </p>
        <p class="card-text mb-1 text-truncate" title="@Model.Venue">
            <strong>Venue:</strong> @Model.Venue
        </p>
        <p class="card-text">
            <strong>Price:</strong> @Model.PriceRange
        </p>

        <div class="mt-auto d-flex gap-2 flex-wrap">
            <a asp-controller="Events" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-primary">View Details</a>

            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Events" asp-action="Edit" asp-route-id="@Model.Id" asp-area="Admin" class="btn btn-outline-secondary">Edit</a>
                <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" asp-area="Admin" data-bs-target="#cancel-event-modal-@Model.Id">Cancel</button>
            }
        </div>
    </div>
</div>

@if (User.IsInRole("Admin"))
{
    var cancelModal = new EventBookingSystem.Areas.Admin.ViewModels.EventCancelModalViewModel
    {
        Id = Model.Id,
        Name = Model.Name,
        ModalId = $"cancel-event-modal-{Model.Id}"
    };

    <partial name="~/Areas/Admin/Views/Events/PartialViews/_CancelEventModal.cshtml"
             model="cancelModal" />
}
