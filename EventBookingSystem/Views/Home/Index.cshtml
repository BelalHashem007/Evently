@model PaginatedViewModel<EventCardViewModel>

@{
    ViewData["Title"] = "Events";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">Events</h1>
        <p class="text-muted mb-0">Browse upcoming events and ticket options.</p>
    </div>

    @if (User.IsInRole("Admin"))
    {
        <a asp-controller="Events" asp-action="Create" asp-area="Admin" class="btn btn-primary">Create New Event</a>
    }

</div>

@if (Model.Items.Count == 0)
{
    <div class="alert alert-info">No events are available yet.</div>
}
else
{
    <div class="row g-4">
        @foreach (var eventItem in Model.Items)
        {
            <div class="col-md-6 col-xl-4">
                <partial name="~/Views/Home/PartialViews/_EventCard.cshtml" model="eventItem" />
            </div>
        }

        <!-- Pagination -->
        <nav aria-label="Page navigation" class="my-4">
            <ul id="pagination-container" class="pagination justify-content-center">
            </ul>
        </nav>

        <input type="hidden" name="page" value="@Model.Page" />
        <input type="hidden" name="totalItems" value="@Model.TotalItems" />
        <input type="hidden" name="maxItemsPerPage" value="@Model.MaxItemsPerPage" />
    </div>
}

<script src="~/js/pagination.js"></script>
