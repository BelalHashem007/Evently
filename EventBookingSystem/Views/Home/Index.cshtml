@model IReadOnlyList<EventBookingSystem.ViewModels.EventCardViewModel>

@{
    ViewData["Title"] = "Events";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">Events</h1>
        <p class="text-muted mb-0">Browse upcoming events and ticket options.</p>
    </div>

    @if (User.IsInRole("Admin"))
    {
        <button type="button" class="btn btn-primary" disabled>Create New Event</button>
    }
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">No events are available yet.</div>
}
else
{
    <div class="row g-4">
        @foreach (var eventItem in Model)
        {
            <div class="col-md-6 col-xl-4">
                <partial name="_EventCard" model="eventItem" />
            </div>
        }
    </div>
}
