@using EventBookingSystem.Models
@model BookingDetailsViewModel

@{
    ViewData["Title"] = $"{Model.EventName}";
    var shouldPollPaymentStatus = string.Equals(TempData["PollPaymentStatus"]?.ToString(), "true", StringComparison.OrdinalIgnoreCase);
}

<div class="mb-4">
    <a asp-action="Index" class="btn btn-link px-0">&larr; Back to my bookings</a>
</div>

<div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Booking #@Model.Id</h1>
        <p class="text-muted mb-0">@Model.EventName</p>
    </div>
    <div class="text-md-end">
        <span class="badge @BookingStatusUi.BadgeClass(Model.Status) fs-6">@Model.Status</span>
        <div class="text-muted small mt-2">Created @Model.CreatedDate.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt")</div>
    </div>
</div>

@if (TempData.Peek("StripeError") != null)
{
    <div class="alert alert-dismissible alert-warning">
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        <h4 class="alert-heading">Warning!</h4>
        <p class="mb-0">@TempData["StripeError"]</p>
    </div>
}

@if (TempData.Peek("StripeMessage") != null)
{
    <div class="alert alert-dismissible alert-info">
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        <p class="mb-0">@TempData["StripeMessage"]</p>
    </div>
}

@if (TempData.Peek("BookingError") != null)
{
    <div class="alert alert-dismissible alert-warning">
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        <p class="mb-0">@TempData["BookingError"]</p>
    </div>
}

@if (TempData.Peek("BookingMessage") != null)
{
    <div class="alert alert-dismissible alert-success">
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        <p class="mb-0">@TempData["BookingMessage"]</p>
    </div>
}

@if (Model.Status == BookingStatus.Pending)
{
    <div class="alert alert-warning">
        Complete payment before @(Model.ExpiresAt?.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt") ?? "the reservation expires") to keep these tickets.
    </div>
}
else if (Model.Status == BookingStatus.Expired)
{
    <div class="alert alert-secondary">
        This reservation expired. The tickets are available for other users again.
    </div>
}
else if (Model.Status == BookingStatus.Cancelled)
{
    <div class="alert alert-secondary">
        This booking was cancelled. The tickets are available for other users again.
    </div>
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="h5 card-title mb-3">Order Summary</h2>
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Ticket</th>
                                <th>Unit Price</th>
                                <th>Quantity</th>
                                <th class="text-end">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>@item.TicketTypeName</td>
                                    <td>@item.UnitPrice.ToString("C")</td>
                                    <td>@item.Quantity</td>
                                    <td class="text-end">@item.TotalPrice.ToString("C")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <th colspan="3" class="text-end">Total</th>
                                <th class="text-end">@Model.TotalPrice.ToString("C")</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h2 class="h5 card-title">Event</h2>
                <p class="mb-1"><strong>Name:</strong> @Model.EventName</p>
                <p class="mb-1"><strong>Date:</strong> @Model.EventDate.ToString("MMM dd, yyyy hh:mm tt")</p>
                <p class="mb-0"><strong>Venue:</strong> @Model.Venue</p>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="h5 card-title">Payment</h2>
                @if (Model.Status == BookingStatus.Pending && Model.ExpiresAt > DateTime.UtcNow)
                {
                    @if (shouldPollPaymentStatus)
                    {
                        <div class="alert alert-info d-flex align-items-center gap-2"
                             data-payment-status-poller
                             data-status-url="@Url.Action("Status", "Bookings", new { id = Model.Id })"
                             data-max-attempts="3"
                             data-delay-ms="2000">
                            <div class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></div>
                            <span data-payment-status-message>Confirming your payment with Stripe...</span>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">Pay securely with Stripe before this reservation expires.</p>
                        <div class="d-grid gap-2">
                            <form asp-controller="Payments" asp-action="CheckOut" asp-area="" method="post">
                                <input type="hidden" name="bookingId" value="@Model.Id"/>
                                <button type="submit" class="btn btn-primary w-100">Proceed to payment</button>
                            </form>
                            <form asp-controller="Bookings" asp-action="Cancel" asp-area="" asp-route-id="@Model.Id" method="post">
                                <button type="submit" class="btn btn-outline-danger w-100">Cancel booking</button>
                            </form>
                        </div>
                    }
                }
                else if (Model.Status == BookingStatus.Confirmed)
                {
                    <p class="text-success mb-0">Payment confirmed. Your booking is complete.</p>
                }
                else if (Model.Status == BookingStatus.Cancelled)
                {
                    <p class="text-muted mb-0">This booking was cancelled.</p>
                }
                else
                {
                    <p class="text-muted">Payment is no longer available for this booking.</p>
                    <button type="button" class="btn btn-primary w-100" disabled>Booking Expired</button>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @if (shouldPollPaymentStatus)
    {
        <partial name="~/Views/Bookings/Scripts/_PaymentStatusPollingScripts.cshtml" />
    }
}
