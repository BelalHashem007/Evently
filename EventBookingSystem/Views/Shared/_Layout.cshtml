@{
    // getting active page
    var currentArea = ViewContext.RouteData.Values["area"]?.ToString();
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    var isPublicArea = string.IsNullOrEmpty(currentArea);
    var isHomeActive = isPublicArea
        && string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase)
        && string.Equals(currentAction, "Index", StringComparison.OrdinalIgnoreCase);
    var isBookingsActive = isPublicArea
        && string.Equals(currentController, "Bookings", StringComparison.OrdinalIgnoreCase);
    var isAdminActive = string.Equals(currentArea, "Admin", StringComparison.OrdinalIgnoreCase);

    // setting up auth modals and returnurl
    var requestedAuthModal = Context.Request.Query["authModal"].ToString();
    var requestedReturnUrl = Context.Request.Query["returnUrl"].ToString();
    var activeAuthModal = ViewData["ActiveAuthModal"] as string;
    if (string.IsNullOrWhiteSpace(activeAuthModal)
        && (string.Equals(requestedAuthModal, "login", StringComparison.OrdinalIgnoreCase)
            || string.Equals(requestedAuthModal, "signup", StringComparison.OrdinalIgnoreCase)))
    {
        activeAuthModal = requestedAuthModal.ToLowerInvariant();
    }

    var authReturnUrl = ViewData["AuthReturnUrl"] as string;
    if (string.IsNullOrWhiteSpace(authReturnUrl)
        && !string.IsNullOrWhiteSpace(requestedReturnUrl)
        && Url.IsLocalUrl(requestedReturnUrl))
    {
        authReturnUrl = requestedReturnUrl;
    }

    if (string.IsNullOrWhiteSpace(authReturnUrl))
    {
        authReturnUrl = string.Concat(Context.Request.PathBase, Context.Request.Path, Context.Request.QueryString);
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Evently</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EventBookingSystem.styles.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg bg-primary mb-3" data-bs-theme="dark">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Evently</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarColor01" aria-controls="navbarColor01" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarColor01">
                    <ul class="navbar-nav ms-auto align-items-lg-center">
                        <li class="nav-item">
                            <a class="nav-link @(isHomeActive ? "active" : "")" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                            {
                                if (User.IsInRole("Admin"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link @(isAdminActive ? "active" : "")" asp-area="Admin" asp-controller="Home" asp-action="Index">Admin</a>
                                    </li>
                                }
                                else
                                {
                                    <li class="nav-item">
                                        <a class="nav-link @(isBookingsActive ? "active" : "")" asp-area="" asp-controller="Bookings" asp-action="Index">My Bookings</a>
                                    </li>
                                }
                                <partial name="~/Views/Shared/PartialViews/_NotificationDropdown.cshtml" />
                                <li class="nav-item">
                                    <span class="nav-link">@User.Identity?.Name</span>
                                </li>
                                <li class="nav-item">
                                    <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                                        <button type="submit" class=" btn text-start text-lg-center p-0 px-lg-3">Logout</button>
                                    </form>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <button class="nav-link" type="button" data-bs-toggle="modal" data-bs-target="#login-modal">Login</button>
                                </li>
                                <li class="nav-item">
                                    <button class="nav-link" type="button" data-bs-toggle="modal" data-bs-target="#signup-modal">Sign Up</button>
                                </li>
                            }
                        </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    @if (User.Identity?.IsAuthenticated != true)
    {
        var loginModel = ViewData["LoginModel"] as LoginViewModel ?? new LoginViewModel();
        var loginModalViewData = new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary<LoginViewModel>(ViewData, loginModel);
        loginModalViewData.TemplateInfo.HtmlFieldPrefix = "Login";
        loginModalViewData["AuthReturnUrl"] = authReturnUrl;

        var signUpModel = ViewData["SignUpModel"] as SignUpViewModel ?? new SignUpViewModel();
        var signUpModalViewData = new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary<SignUpViewModel>(ViewData, signUpModel);
        signUpModalViewData.TemplateInfo.HtmlFieldPrefix = "SignUp";
        signUpModalViewData["AuthReturnUrl"] = authReturnUrl;

        <partial name="~/Views/Shared/PartialViews/_LoginModal.cshtml"
                 model="loginModel"
                 view-data="loginModalViewData" />
        <partial name="~/Views/Shared/PartialViews/_SignUpModal.cshtml"
                 model="signUpModel"
                 view-data="signUpModalViewData" />
    }

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Evently
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/dateConversion.js"></script>
    @if (User.Identity?.IsAuthenticated != true)
    {
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
        <script src="~/js/auth-modals.js" asp-append-version="true"></script>
    }
    @if (User.Identity?.IsAuthenticated == true)
        {
            <script src="~/lib/microsoft/signalr/dist/webworker/signalr.js" asp-append-version="true"></script>
            <script src="~/js/notification.js" asp-append-version="true"></script>
        }
    @if (!string.IsNullOrWhiteSpace(activeAuthModal))
    {
        var activeAuthModalId = string.Equals(activeAuthModal, "signup", StringComparison.OrdinalIgnoreCase)
            ? "signup-modal"
            : "login-modal";

        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const authModal = document.getElementById('@activeAuthModalId');
                if (authModal) {
                    bootstrap.Modal.getOrCreateInstance(authModal).show();
                }
            });
        </script>
    }
        
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
