@model EventDetailsViewModel

@{
    ViewData["Title"] = Model.Name;
    var hasAvailableTickets = Model.TicketTypes.Any(t => t.AvailableQuantity > 0);
    var returnUrl = Url.Action("Details", "Events", new { id = Model.Id });
}

<div class="mb-4">
    <a asp-controller="Home" asp-action="Index" class="btn btn-link px-0">&larr; Back to events</a>
</div>

<!-- Info + Admin buttons-->
@if (Model.IsCancelled)
{
    <div class="alert alert-warning">This event has been cancelled.</div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (User.IsInRole("Admin") && !Model.IsCancelled)
{
    <div class="d-flex gap-2 mb-4">
        <a asp-controller="Events" asp-action="Edit" asp-route-id="@Model.Id" asp-area="Admin" class="btn btn-secondary">Edit</a>
        <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#cancel-event-modal-@Model.Id">Cancel</button>
    </div>
}

<!-- Actual page content-->

<section class="mb-4">
    @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
    {
        <img src="@Model.ImageUrl" class="img-fluid rounded w-100" alt="@Model.Name" style="max-height: 420px; object-fit: cover;" />
    }
    else
    {
        <div class="bg-light d-flex align-items-center justify-content-center text-muted rounded" style="height: 320px;">
            No image available
        </div>
    }
</section>

<div class="mb-4">
    <h1 class="mb-2">@Model.Name</h1>
    <p class="text-muted mb-0">@(Model.Date.ToString("MMMM dd, yyyy")) | @(Model.Date.ToString("hh:mm")) @(Model.Date.ToString("tt"))</p>
</div>

<section class="card shadow-sm mb-4">
    <div class="card-body">
        <h2 class="h4 card-title">About Event</h2>
        <p class="card-text mb-0">@Model.Description</p>
    </div>
</section>

<section class="mb-4">
    <h2 class="h4 mb-3">Tickets</h2>

    @if (Model.TicketTypes.Count == 0)
    {
        <div class="alert alert-info">No ticket types are available for this event yet.</div>
    }
    else
    {
        @if (User.Identity?.IsAuthenticated != true)
        {
            <div class="alert alert-info d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
                <span>Sign in or create an account to book tickets for this event.</span>
                <span class="d-flex gap-2">
                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#login-modal">Login</button>
                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#signup-modal">Sign Up</button>
                </span>
            </div>
        }

        <form asp-controller="Bookings" asp-action="Create" method="post">
            <input type="hidden" name="EventId" value="@Model.Id" />
            <div class="row g-3">
                @for (var i = 0; i < Model.TicketTypes.Count; i++)
                {
                    var ticketType = Model.TicketTypes[i];
                    var isSoldOut = ticketType.AvailableQuantity <= 0;

                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100">
                            <div class="card-body d-flex flex-column">
                                <h3 class="h5 card-title">@ticketType.Name</h3>
                                <p class="card-text mb-1">
                                    <strong>Price:</strong> @ticketType.Price.ToString("C")
                                </p>
                                <p class="card-text mb-3">
                                    <strong>Amount left:</strong> @ticketType.AvailableQuantity
                                </p>
                                <input type="hidden" name="Tickets[@i].TicketTypeId" value="@ticketType.Id" />
                                <label for="ticket-quantity-@ticketType.Id" class="form-label mt-auto">Quantity</label>
                                <input id="ticket-quantity-@ticketType.Id"
                                       name="Tickets[@i].Quantity"
                                       type="number"
                                       min="0"
                                       max="@ticketType.AvailableQuantity"
                                       value="0"
                                       class="form-control"
                                       disabled="@(isSoldOut || Model.IsCancelled)" />
                                @if (isSoldOut)
                                {
                                    <span class="badge text-bg-secondary mt-3 align-self-start">Sold out</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary" disabled="@(Model.IsCancelled || !hasAvailableTickets)">
                    @(User.Identity?.IsAuthenticated == true ? "Reserve Tickets" : "Login to Book")
                </button>
            </div>
        </form>
    }
</section>

<section class="card shadow-sm">
    <div class="card-body">
        <h2 class="h5 card-title">Venue</h2>
        <p class="card-text mb-0">@Model.Venue</p>
    </div>
</section>

@if (User.IsInRole("Admin") && !Model.IsCancelled)
{

    var cancelModal = new EventBookingSystem.Areas.Admin.ViewModels.EventCancelModalViewModel
    {
        Id = Model.Id,
        Name = Model.Name,
        ModalId = $"cancel-event-modal-{Model.Id}"
    };

    <partial name="~/Areas/Admin/Views/Events/PartialViews/_CancelEventModal.cshtml"
             model="cancelModal" />
}
