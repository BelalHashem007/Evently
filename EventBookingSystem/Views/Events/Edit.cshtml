@model EventBookingSystem.ViewModels.EventFormViewModel

@{
    ViewData["Title"] = "Edit Event";
}

<div class="mb-4">
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-link px-0">&larr; Back to event</a>
</div>

<h1 class="mb-4">Edit Event</h1>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <partial name="/Views/Events/PartialViews/_EventForm.cshtml" model="Model" />

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <partial name="/Views/Events/PartialViews/_EventFormScripts.cshtml" />
}
